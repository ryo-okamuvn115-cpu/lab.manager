{
  "name": "lab-manager-web",
  "version": "1.0.0",
  "description": "Lab Manager Web Version",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "node server/lab-server.js",
    "build": "vite build",
    "build:android": "vite build && npx cap sync android",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:open:android": "npx cap open android",
    "preview": "vite preview --host 0.0.0.0",
    "type-check": "tsc --noEmit",
    "start": "node server/lab-server.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
